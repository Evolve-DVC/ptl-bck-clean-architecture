# Proyecto Java/Gradle multi-modulo

# Build artifacts
.gradle/
**/build/
!src/**/build/

# IDEs
.idea/
*.iml
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Java / JVM
*.class
*.log
*.hprof
hs_err_pid*
replay_pid*

# Environment files
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Tool caches / local history
.history/
.ionide

# Keep Gradle wrapper tracked
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
